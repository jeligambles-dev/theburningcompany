# ============================================
# THE BURNING COMPANY — Environment Variables
# Copy to .env and fill in your values
# ============================================

# ------- Solana / Blockchain -------
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=
SOLANA_NETWORK=mainnet-beta
AGENT_WALLET_PRIVATE_KEY=
AGENT_TOKEN_MINT_ADDRESS=
CURRENCY_MINT=So11111111111111111111111111111111111111112
BURN_ADDRESS=1nc1nerator11111111111111111111111111111111

# ------- Pump.fun Agent SDK -------
PUMPFUN_API_KEY=
PUMPFUN_AGENT_ID=

# ------- Burn Engine -------
BURN_PERCENTAGE=80
TREASURY_PERCENTAGE=20
BURN_THRESHOLD_SOL=0.5
BURN_CHECK_INTERVAL_MS=60000
JUPITER_SWAP_SLIPPAGE_BPS=100
BURN_POLL_INTERVAL_MS=30000

# ------- Twitter / X API (v2) -------
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# ------- Tweet Schedule -------
TWEET_BURN_ALERTS=true
TWEET_SHITPOST_INTERVAL_HOURS=6
TWEET_TREASURY_REPORT_DAY=monday

# ------- Agent Personality (LLM) -------
# Uses Anthropic Claude for tweet generation
ANTHROPIC_API_KEY=

# ------- Mention Rewards (anti-exploit) -------
REWARD_PER_MENTION=1000
MAX_DAILY_REWARDS=50000
MAX_REWARDS_PER_USER_PER_DAY=2
REWARD_MIN_ACCOUNT_AGE_DAYS=30
REWARD_MIN_FOLLOWERS=10

# ------- Website / Server -------
PORT=3000
NODE_ENV=production
SITE_URL=https://burningcompany.xyz

# ------- Railway -------
RAILWAY_ENVIRONMENT=production
